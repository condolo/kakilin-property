# ── Kakilin Properties — Environment Variables ──────────────────
#
# 1. Copy this file to .env  (never commit .env to git)
# 2. Fill in all values below
# 3. On Render.com: add each key under Environment → Add env var

# ── MongoDB Atlas ─────────────────────────────────────────────
# Atlas → your cluster → Connect → Drivers → copy URI
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/kakilin?retryWrites=true&w=majority

# ── Email Notifications (Gmail SMTP) ──────────────────────────
# Use a Gmail account dedicated to Kakilin (not your personal one)
# Enable 2FA on the Gmail, then generate an App Password:
# Gmail → Settings → Security → 2-Step Verification → App Passwords
MAIL_USER=kakilin.notifications@gmail.com
MAIL_PASS=xxxx xxxx xxxx xxxx

# Admin email — where to receive all inquiry/booking alerts
ADMIN_EMAIL=admin@kakilin.co.ke

# ── Server ────────────────────────────────────────────────────
# Render sets PORT automatically — leave as-is for local
PORT=3002
