# ── Kakilin Properties — Environment Variables ──────────────────
#
# 1. Copy this file to .env  (never commit .env to git)
# 2. Fill in your MongoDB Atlas connection string
# 3. For Render.com: add MONGODB_URI in Environment → Add env var

# MongoDB Atlas connection string
# Get it from: Atlas → your cluster → Connect → Drivers → copy URI
# Replace <username>, <password>, and <dbname> with your values
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/<dbname>?retryWrites=true&w=majority

# Server port (Render sets this automatically — leave as-is for local)
PORT=3002
